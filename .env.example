# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# OpenAI API key (used by agent inference scripts)
OPENAI_API_KEY=sk-...

# Anthropic Claude API key — required for Phase 2 AI brain.
# Obtain at https://console.anthropic.com/
# Used by env/environment.py (_handle_classify) and scan_github.py
# when license confidence < 0.5 or SPDX result is UNKNOWN.
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string (docker-compose sets this automatically)
DATABASE_URL=postgresql://pragati:pragati123@localhost:5432/UnderWire_db
